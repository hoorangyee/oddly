# Polly 환경 변수 예시 — 이 파일을 .env 로 복사해서 채우세요.

# --- Database (libSQL / SQLite) ---
# 개발: 로컬 SQLite 파일.   운영: Turso  →  libsql://<db>-<org>.turso.io
DATABASE_URL="file:./dev.db"
# Turso 운영에서만 필요(로컬 file: 에서는 비워둠). turso db tokens create <db>
DATABASE_AUTH_TOKEN=""

# --- File storage (Vercel Blob) ---
# 커스텀 이모지 업로드용. Vercel Blob 스토어를 연결하면 주입되는 read/write 토큰.
BLOB_READ_WRITE_TOKEN=""

# --- Auth / Session ---
# 멤버 세션 쿠키 서명용 비밀키. 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-32-bytes-hex"

# 슈퍼관리자 키. 이 값을 아는 사람만 조직을 생성/삭제할 수 있음(=인스턴스 운영자).
SUPER_ADMIN_KEY="change-me-super-admin-key"
